generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  dailyCalGoal  Int      @default(2000)
  dailyProteinG Int      @default(150)
  dailyCarbsG   Int      @default(250)
  dailyFatG     Int      @default(65)
  meals         Meal[]
}

model Meal {
  id            String     @id @default(cuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  loggedAt      DateTime   @default(now())
  category      String     // BREAKFAST | LUNCH | DINNER | SNACK
  photoPath     String?
  notes         String?
  totalCals     Int        @default(0)
  totalProteinG Float      @default(0)
  totalCarbsG   Float      @default(0)
  totalFatG     Float      @default(0)
  foodItems     FoodItem[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([userId, loggedAt])
}

model FoodItem {
  id         String  @id @default(cuid())
  mealId     String
  meal       Meal    @relation(fields: [mealId], references: [id], onDelete: Cascade)
  name       String
  quantity   String
  calories   Int
  proteinG   Float
  carbsG     Float
  fatG       Float
  confidence Float?

  @@index([mealId])
}
